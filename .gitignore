## .NET Core / .NET 10 API - .gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
.vshistory/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider / JetBrains
.idea/
*.sln.iml

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# Build Logs
*.log
*.tlog
*.binlog

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# .NET Core
*.dll
*.pdb
*.exe

# Publish output
**/[Pp]ublish/
*.[Pp]ublish.xml
*.azurePubxml
PublishProfiles/

# Secrets & local configuration (IMPORTANT for APIs)
appsettings.Development.json
appsettings.*.local.json
secrets.json
*.pfx
*.p12
*.key
*.pem

# User secrets (these live outside repo by default, but just in case)
**/secrets/

# Environment variables
.env
.env.*

# Database files
*.mdf
*.ldf
*.ndf
*.db
*.sqlite
*.sqlite3

# EF Core migrations bin (keep migration .cs files, ignore bin/obj already covered above)

# Docker
*.dockerignore.bak
docker-compose.override.yml

# OS-specific files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains Rider
*.sln.DotSettings.user

# Test Results
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage/
*.opencover.xml

# Backup & temp files
*.bak
*.tmp
*.swp
*~

# Node (if using JS tooling alongside API, e.g. for client or build scripts)
node_modules/
npm-debug.log*

# Misc
*.cache
*.DotSettings.user
.editorconfig.user